# ============================================================================
# MELODIA - Production Environment Configuration
# ============================================================================
# IMPORTANT: This is an example file. Copy to .env and fill with real values.
# NEVER commit the actual .env file to version control.
# ============================================================================

# ---- ENVIRONMENT & DEPLOYMENT ----
NODE_ENV=production
PORT=5000
CLIENT_URL=https://melodia-client.render.com
SERVER_URL=https://melodia-server.render.com

# ---- DATABASE CONFIGURATION ----
# MongoDB Atlas URI (recommended for production on Render)
# Format: mongodb+srv://username:password@cluster.mongodb.net/melodia?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/melodia
MONGO_DB_NAME=melodia

# ---- AUTHENTICATION & SECURITY ----
# Generate strong JWT secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_characters_long
JWT_REFRESH_EXPIRE=30d

# Bcrypt salt rounds (10-12 recommended)
BCRYPT_ROUNDS=12

# CORS configuration (comma-separated for multiple origins)
CORS_ORIGIN=https://melodia-client.render.com,https://your-custom-domain.com

# ---- CLOUD STORAGE (Firebase or Cloudinary) ----
# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_email

# ---- SPOTIFY API INTEGRATION ----
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://melodia-server.render.com/api/auth/spotify/callback

# ---- AI & RECOMMENDATIONS ENGINE ----
# OpenAI API (for Smart Playlist generation using GPT)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# ---- EMAIL SERVICE (for notifications & password reset) ----
# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDER_EMAIL=noreply@melodia.app
SENDER_NAME=Melodia

# ---- REDIS (for caching and sessions) ----
REDIS_URL=redis://default:password@redis.render.com:10000
REDIS_TTL=3600

# ---- LOGGING & MONITORING ----
# Sentry for error tracking
SENTRY_DSN=https://your_sentry_dsn@sentry.io/123456

# Logging level
LOG_LEVEL=info

# ---- FILE UPLOAD CONSTRAINTS ----
MAX_AUDIO_FILE_SIZE=52428800  # 50MB in bytes
MAX_IMAGE_FILE_SIZE=5242880   # 5MB in bytes
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,ogg,m4a
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

# ---- TESTING & DEVELOPMENT ----
DEBUG=false

# ---- PAGINATION ----
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================================
# DEPLOYMENT NOTES:
# ============================================================================
# 1. Use Render Environment Variables for sensitive data
# 2. Database: Connect MongoDB Atlas for scalability
# 3. Cloud Storage: Use Firebase Storage for reliable CDN
# 4. Email: Configure SendGrid for transactional emails
# 5. Monitoring: Set up Sentry for production error tracking
# 6. Performance: Enable Redis caching for sessions and data
# 7. Security: Always use HTTPS, enable CORS selectively, implement rate limiting
# ============================================================================
